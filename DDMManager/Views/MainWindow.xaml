<Window x:Class="DDMManager.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="DDM Manager — Metalfrio"
        Width="1160" Height="760"
        MinWidth="980" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource SystemControlPageBackgroundAltHighBrush}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <!-- Atalhos globais -->
    <Window.InputBindings>
        <KeyBinding Key="F5"  Command="{Binding AtualizarCommand, RelativeSource={RelativeSource Self}}"/>
        <KeyBinding Key="P"   Modifiers="Ctrl" Command="{Binding GerarPdfCommand,  RelativeSource={RelativeSource Self}}"/>
        <KeyBinding Key="D"   Modifiers="Ctrl" Command="{Binding GerarDocxCommand, RelativeSource={RelativeSource Self}}"/>
        <KeyBinding Key="Left"  Modifiers="Alt" Command="{Binding SemanaAnteriorCommand, RelativeSource={RelativeSource Self}}"/>
        <KeyBinding Key="Right" Modifiers="Alt" Command="{Binding SemanaProximaCommand,  RelativeSource={RelativeSource Self}}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Accent bar -->
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Path bar -->
            <RowDefinition Height="Auto"/>  <!-- Status bar (checklist) -->
            <RowDefinition Height="*"/>     <!-- Body -->
            <RowDefinition Height="Auto"/>  <!-- Footer -->
        </Grid.RowDefinitions>

        <!-- ── Accent bar ── -->
        <Rectangle Grid.Row="0" Height="3" Fill="{StaticResource MetalfrioAccent}"/>

        <!-- ── Header ── -->
        <Border Grid.Row="1"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="20,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="&#10052;" FontSize="28"
                               Foreground="{StaticResource MetalfrioAccent}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DDM Manager"
                                   FontSize="20" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Metalfrio Solutions  ·  Engenharia de Produto"
                                   FontSize="10" Opacity="0.5"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Relógio + atalhos hint -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="F5=Atualizar  Ctrl+P=PDF  Ctrl+D=DOCX  Alt+◄►=Semana"
                               FontSize="9" Opacity="0.35"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="4" Padding="10,6">
                        <TextBlock x:Name="TxtRelogio" FontSize="10" Opacity="0.7"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Barra de caminhos ── -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="16,8">
            <StackPanel>
                <!-- Pasta raiz -->
                <Grid Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#128193;  PASTA RAIZ DDM 2026"
                               FontSize="10" FontWeight="SemiBold" Opacity="0.6"
                               VerticalAlignment="Center"/>
                    <ui:TextBox Grid.Column="1" x:Name="TxtRaiz"
                                FontSize="12" Padding="8,4"/>
                    <Button Grid.Column="2" Content="  …  "
                            Style="{StaticResource PrimaryButton}"
                            FontSize="11" FontWeight="Bold"
                            Margin="6,0,0,0" Padding="12,4"
                            Click="BtnBrowseRaiz_Click"/>
                    <Button Grid.Column="3" Content="&#128260;  Atualizar  [F5]"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="11" Margin="6,0,0,0" Padding="12,4"
                            Click="BtnAtualizar_Click"/>
                </Grid>
                <!-- Pasta saída -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#128190;  SALVAR EM"
                               FontSize="10" FontWeight="SemiBold" Opacity="0.6"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" x:Name="TxtSaida"
                               Text="(padrão: mesma pasta do DDM)"
                               FontSize="11" Opacity="0.45" VerticalAlignment="Center"/>
                    <Button Grid.Column="2" Content="Alterar" FontSize="10"
                            Style="{StaticResource SecondaryButton}"
                            Margin="6,0,0,0" Padding="10,3"
                            Click="BtnBrowseSaida_Click"/>
                    <Button Grid.Column="3" Content="✕" FontSize="10"
                            Style="{StaticResource DangerButton}"
                            Margin="4,0,0,0" Padding="8,3"
                            Click="BtnLimparSaida_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ── Status bar: checklist pré-geração ── -->
        <Border Grid.Row="3" x:Name="StatusBar"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                Padding="16,6" BorderThickness="0,1,0,1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="VERIFICAÇÕES:" FontSize="9" FontWeight="SemiBold"
                           Opacity="0.5" VerticalAlignment="Center" Margin="0,0,16,0"/>
                <TextBlock x:Name="ChkPastaRaiz"  FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ChkWord"        FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ChkDdms"        FontSize="10" Margin="0,0,16,0" VerticalAlignment="Center"/>
                <TextBlock x:Name="ChkCampos"      FontSize="10" Margin="0,0,0,0"  VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- ── Body ── -->
        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="290"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Col 1: Campos cabeçalho ── -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="CABEÇALHO DDM" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.5" Margin="0,0,0,12"/>

                    <TextBlock Text="&#127981;  SETOR / LINHA" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="TxtSetor" FontSize="12" Margin="0,0,0,14"
                                TextChanged="Campo_Changed"/>

                    <TextBlock Text="&#128313;  SUBÁREA" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="TxtSubarea" FontSize="12" Margin="0,0,0,14"
                                TextChanged="Campo_Changed"/>

                    <TextBlock Text="&#9200;  TURNO" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="TxtTurno" FontSize="12" Margin="0,0,0,14"
                                TextChanged="Campo_Changed"/>

                    <TextBlock Text="&#128100;  FACILITADOR" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.6" Margin="0,0,0,4"/>
                    <ui:TextBox x:Name="TxtFacilitador" FontSize="12" Margin="0,0,0,20"
                                TextChanged="Campo_Changed"/>

                    <Border Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="4" Padding="12,10">
                        <TextBlock FontSize="12">
                            <Run Text="&#128101;  "/>
                            <Run x:Name="RunNParticipantes" Text="18"
                                 Foreground="{StaticResource MetalfrioSuccess}"/>
                            <Run Text=" participantes carregados"
                                 Foreground="{StaticResource MetalfrioSuccess}"/>
                        </TextBlock>
                    </Border>

                    <!-- Impressora -->
                    <TextBlock Text="&#128424;  IMPRESSORA" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.6" Margin="0,20,0,4"/>
                    <ComboBox x:Name="CmbImpressora" FontSize="11"
                              HorizontalAlignment="Stretch"/>
                    <TextBlock Text="(padrão do sistema se não selecionada)"
                               FontSize="9" Opacity="0.4" Margin="0,3,0,0"/>

                    <!-- Notificação semanal -->
                    <Border Margin="0,20,0,0"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="4" Padding="12,10">
                        <StackPanel>
                            <TextBlock Text="&#128276;  LEMBRETE SEMANAL" FontSize="10"
                                       FontWeight="SemiBold" Opacity="0.6" Margin="0,0,0,6"/>
                            <TextBlock x:Name="TxtStatusNotif" FontSize="10"
                                       Opacity="0.6" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="BtnAtivarNotif" Content="Ativar"
                                        Style="{StaticResource SecondaryButton}"
                                        FontSize="10" Padding="10,4"
                                        Click="BtnAtivarNotif_Click"/>
                                <Button x:Name="BtnDesativarNotif" Content="Desativar"
                                        Style="{StaticResource DangerButton}"
                                        FontSize="10" Padding="10,4" Margin="6,0,0,0"
                                        Click="BtnDesativarNotif_Click"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Rectangle Grid.Column="1"
                       Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Width="1"/>

            <!-- ── Col 2: Lista DDMs ── -->
            <Grid Grid.Column="2" Margin="0,12,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Navegação de semana -->
                <Grid Grid.Row="0" Margin="16,0,16,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="◄  [Alt+←]"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="10" Padding="8,3"
                            Click="BtnSemanaAnterior_Click"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="SEMANA" FontSize="10" FontWeight="SemiBold"
                                   Opacity="0.5" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtSemana" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource MetalfrioAccent}"
                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtSemanaLabel" FontSize="9"
                                   Opacity="0.4" Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button Grid.Column="2" Content="[Alt+►]  ►"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="10" Padding="8,3"
                            Click="BtnSemanaProxima_Click"/>
                </Grid>

                <!-- Cabeçalho lista -->
                <Border Grid.Row="1"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="12,6" Margin="0,0,0,2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="✔" FontSize="10" Opacity="0.4"/>
                        <TextBlock Grid.Column="1" Text="DIA"  FontSize="10" FontWeight="SemiBold" Opacity="0.4"/>
                        <TextBlock Grid.Column="2" Text="TEMA" FontSize="10" FontWeight="SemiBold" Opacity="0.4"/>
                        <TextBlock Grid.Column="3" Text="DATA" FontSize="10" FontWeight="SemiBold" Opacity="0.4" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- Lista DDMs -->
                <ItemsControl Grid.Row="2" x:Name="ListaDdms">
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,9" Margin="0,1,0,0"
                                    Cursor="{Binding TemArquivo,
                                        Converter={StaticResource BoolToCursorConverter}}">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.ToggleSelecaoCommand,
                                                      RelativeSource={RelativeSource AncestorType=Window}}"
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding EhHoje}" Value="True">
                                                <Setter Property="Background"
                                                        Value="{DynamicResource SystemControlHighlightListAccentLowBrush}"/>
                                                <Setter Property="BorderBrush"
                                                        Value="{StaticResource MetalfrioAccent}"/>
                                                <Setter Property="BorderThickness" Value="3,0,0,0"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="28"/>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding Selecionado}"
                                              IsEnabled="{Binding TemArquivo}"
                                              VerticalAlignment="Center"/>

                                    <TextBlock Grid.Column="1" Text="{Binding DiaAbrev}"
                                               FontSize="11" FontWeight="SemiBold"
                                               VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EhHoje}" Value="True">
                                                        <Setter Property="Foreground"
                                                                Value="{StaticResource MetalfrioAccent}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="2" FontSize="11"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="{Binding Tema}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TemArquivo}" Value="False">
                                                        <Setter Property="Text" Value="— sem arquivo —"/>
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBlock Grid.Column="3" Text="{Binding DataDdm}"
                                               FontSize="10" Opacity="0.45"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Botões seleção -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="12,8">
                    <Button Content="Selecionar tudo" FontSize="11"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,4" Margin="0,0,6,0"
                            Click="BtnSelecionarTudo_Click"/>
                    <Button Content="Limpar seleção" FontSize="11"
                            Style="{StaticResource DangerButton}"
                            Padding="12,4"
                            Click="BtnLimparSelecao_Click"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Column="3"
                       Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Width="1"/>

            <!-- ── Col 3: Preview ── -->
            <ScrollViewer Grid.Column="4" VerticalScrollBarVisibility="Auto" Padding="14,14">
                <StackPanel>
                    <TextBlock Text="PREVIEW" FontSize="10" FontWeight="SemiBold"
                               Opacity="0.5" Margin="0,0,0,12"/>

                    <Border x:Name="PreviewPanel"
                            Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                            CornerRadius="6" Padding="14">
                        <StackPanel>
                            <TextBlock Text="Selecione um DDM" FontSize="11"
                                       Opacity="0.4" FontStyle="Italic"
                                       x:Name="TxtPreviewVazio"/>

                            <StackPanel x:Name="PreviewConteudo" Visibility="Collapsed">
                                <TextBlock x:Name="PreviewDia"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource MetalfrioAccent}"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="TEMA" FontSize="9" FontWeight="SemiBold"
                                           Opacity="0.5" Margin="0,0,0,3"/>
                                <TextBlock x:Name="PreviewTema" FontSize="11"
                                           TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <TextBlock Text="DATA" FontSize="9" FontWeight="SemiBold"
                                           Opacity="0.5" Margin="0,0,0,3"/>
                                <TextBlock x:Name="PreviewData" FontSize="11"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="ARQUIVO" FontSize="9" FontWeight="SemiBold"
                                           Opacity="0.5" Margin="0,0,0,3"/>
                                <TextBlock x:Name="PreviewArquivo" FontSize="10"
                                           Opacity="0.7" TextWrapping="Wrap"
                                           Margin="0,0,0,10"/>

                                <TextBlock Text="CABEÇALHO QUE SERÁ PREENCHIDO"
                                           FontSize="9" FontWeight="SemiBold"
                                           Opacity="0.5" Margin="0,0,0,6"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Setor:"
                                               FontSize="10" Opacity="0.5"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="PrvSetor"
                                               FontSize="10" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Turno:"
                                               FontSize="10" Opacity="0.5" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="PrvTurno"
                                               FontSize="10" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Facilitador:"
                                               FontSize="10" Opacity="0.5" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="PrvFacilitador"
                                               FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Data:"
                                               FontSize="10" Opacity="0.5" Margin="0,4,0,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="PrvData"
                                               FontSize="10" Margin="0,4,0,0"/>
                                </Grid>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Rectangle Grid.Column="5"
                       Fill="{DynamicResource SystemControlForegroundBaseLowBrush}" Width="1"/>

            <!-- ── Col 4: Log ── -->
            <Grid Grid.Column="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="14,8">
                    <Grid>
                        <TextBlock Text="LOG DE EXECUÇÃO" FontSize="10"
                                   FontWeight="SemiBold" Opacity="0.5"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Histórico" FontSize="9"
                                    Style="{StaticResource SecondaryButton}"
                                    Padding="8,2" Margin="0,0,6,0"
                                    Click="BtnHistorico_Click"
                                    x:Name="BtnHistorico"/>
                            <Button Content="Limpar" FontSize="9"
                                    Style="{StaticResource DangerButton}"
                                    Padding="8,2"
                                    Click="BtnLimparLog_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <RichTextBox Grid.Row="1" x:Name="RtbLog"
                             IsReadOnly="True" Background="Transparent"
                             BorderThickness="0"
                             FontFamily="Cascadia Code, Consolas"
                             FontSize="11" Padding="12,8"
                             VerticalScrollBarVisibility="Auto"/>

                <!-- Barra de progresso -->
                <Border Grid.Row="2" x:Name="ProgressBar" Visibility="Collapsed"
                        Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                        Padding="14,8">
                    <StackPanel>
                        <TextBlock x:Name="TxtProgresso" FontSize="10" Opacity="0.7"
                                   Margin="0,0,0,4"/>
                        <ui:ProgressBar x:Name="Progresso" IsIndeterminate="True" Height="4"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- ── Footer ── -->
        <Border Grid.Row="5"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Botões principais -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="📄   Gerar DOCX  [Ctrl+D]"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="18,10" Click="BtnGerarDocx_Click"/>

                    <Button Content="📋   Combinar DOCX"
                            Style="{StaticResource SecondaryButton}"
                            Foreground="{StaticResource MetalfrioAccent2}"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="18,10" Margin="8,0,0,0"
                            Click="BtnCombinarDocx_Click"/>

                    <Button Content="📑   Gerar PDF + Abrir  [Ctrl+P]"
                            Style="{StaticResource PrimaryButton}"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="18,10" Margin="8,0,0,0"
                            Click="BtnGerarPdf_Click"/>

                    <Button Content="🖨️   Imprimir direto"
                            Style="{StaticResource SecondaryButton}"
                            Foreground="{StaticResource MetalfrioSuccess}"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="18,10" Margin="8,0,0,0"
                            Click="BtnImprimirDireto_Click"/>

                    <Button Content="📊   Relatório"
                            Style="{StaticResource SecondaryButton}"
                            FontSize="12" FontWeight="SemiBold"
                            Padding="18,10" Margin="8,0,0,0"
                            Click="BtnRelatorio_Click"/>
                </StackPanel>

                <!-- Sair -->
                <Button Grid.Column="1" Content="✖   Sair"
                        Style="{StaticResource DangerButton}"
                        FontSize="12" FontWeight="SemiBold"
                        Padding="18,10" Click="BtnSair_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
